@model LoanApp.Models.PaginatedList<LoanApp.Models.BalanceViewModel>
@inject ICurrentUserService CurrentUser

@{
    ViewData["Title"] = CurrentUser.IsAdmin ? "لوحة الأرصدة" : "رصيدي";
    var details = ViewBag.BalanceDetails as LoanApp.Models.PaginatedList<LoanApp.Models.BalancePartyDetailViewModel>;
}

<div class="mb-4">
    <h2 class="fw-bold text-dark">@(CurrentUser.IsAdmin ? "لوحة تحكم الأرصدة" : "رصيدي")</h2>
    <p class="text-muted">@(CurrentUser.IsAdmin ? "نظرة عامة على جميع القروض النشطة وصافي الأرصدة عبر الفريق." : "عرض رصيدك الحالي فقط.")</p>
</div>

@if (!CurrentUser.IsAdmin && details != null && details.Items.Any())
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
        <div class="card-body border-bottom bg-light-subtle">
            <h5 class="mb-1 fw-bold text-dark">تفصيل الرصيد حسب الشخص</h5>
            <p class="mb-0 text-muted small">يوضح هذا الجدول: لك على من، وعليك لمن.</p>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle balance-table">
                <thead class="balance-table-head">
                    <tr>
                        <th class="ps-4 py-3 text-start">الشخص</th>
                        <th class="py-3 text-start">لك عليه</th>
                        <th class="py-3 text-start">عليك له</th>
                        <th class="py-3 text-start">الصافي</th>
                        <th class="py-3 text-start">آخر عملية</th>
                        <th class="pe-4 py-3 text-start">البيان</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in details.Items)
                    {
                        <tr>
                            <td class="ps-4 fw-medium text-start">@item.PersonName</td>
                            <td class="text-success fw-medium text-start">@item.LentToPerson.ToString("C")</td>
                            <td class="text-danger fw-medium text-start">@item.BorrowedFromPerson.ToString("C")</td>
                            <td class="text-start">
                                @if (item.NetBalance > 0)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                                        +@item.NetBalance.ToString("C")
                                    </span>
                                }
                                else if (item.NetBalance < 0)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill">
                                        @item.NetBalance.ToString("C")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 rounded-pill">
                                        @item.NetBalance.ToString("C")
                                    </span>
                                }
                            </td>
                            <td class="text-muted text-start">@(item.LastOperationDate?.ToShortDateString() ?? "-")</td>
                            <td class="pe-4 text-start">
                                @if (item.NetBalance > 0)
                                {
                                    <span class="text-success fw-medium">لك على @item.PersonName</span>
                                }
                                else if (item.NetBalance < 0)
                                {
                                    <span class="text-danger fw-medium">عليك لـ @item.PersonName</span>
                                }
                                else
                                {
                                    <span class="text-muted">متوازن</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (details.TotalPages > 1)
    {
        <nav aria-label="تفصيل الرصيد" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(details.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link rounded-pill px-3" asp-action="Index" asp-route-pageNumber="@Model.PageIndex" asp-route-detailsPageNumber="@(details.PageIndex - 1)">السابق</a>
                </li>
                <li class="page-item disabled mx-2">
                    <span class="page-link border-0 bg-transparent text-dark fw-bold">صفحة @details.PageIndex من @details.TotalPages</span>
                </li>
                <li class="page-item @(details.HasNextPage ? "" : "disabled")">
                    <a class="page-link rounded-pill px-3" asp-action="Index" asp-route-pageNumber="@Model.PageIndex" asp-route-detailsPageNumber="@(details.PageIndex + 1)">التالي</a>
                </li>
            </ul>
        </nav>
    }
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle balance-table">
            <thead class="balance-table-head">
                <tr>
                    <th class="ps-4 py-3 text-start">الموظف</th>
                    <th class="py-3 text-start">إجمالي ما أقرضه</th>
                    <th class="py-3 text-start">إجمالي ما اقترضه</th>
                    <th class="pe-4 py-3 text-start">الرصيد النهائي</th>
                        <th class="pe-4 py-3 text-start">آخر عملية</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="ps-4 fw-medium text-start">@item.EmployeeName</td>
                        <td class="text-success fw-medium text-start">@item.TotalLent.ToString("C")</td>
                        <td class="text-danger fw-medium text-start">@item.TotalBorrowed.ToString("C")</td>
                        <td class="pe-4 text-start">
                            @if (item.Balance > 0)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                                    +@item.Balance.ToString("C")
                                </span>
                            }
                            else if (item.Balance < 0)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill">
                                    @item.Balance.ToString("C")
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 rounded-pill">
                                    @item.Balance.ToString("C")
                                </span>
                            }
                        </td>
                        <td class="pe-4 text-muted text-start">@(item.LastOperationDate?.ToShortDateString() ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="الأرصدة" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link rounded-pill px-3" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-detailsPageNumber="@(details?.PageIndex ?? 1)">السابق</a>
            </li>
            <li class="page-item disabled mx-2">
                <span class="page-link border-0 bg-transparent text-dark fw-bold">صفحة @Model.PageIndex من @Model.TotalPages</span>
            </li>
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link rounded-pill px-3" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-detailsPageNumber="@(details?.PageIndex ?? 1)">التالي</a>
            </li>
        </ul>
    </nav>
}


