@model LoanApp.Models.EmployeeLoginViewModel

@{
    ViewData["Title"] = "تسجيل الدخول";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <h2 class="fw-bold text-dark mb-2">تسجيل الدخول المؤقت</h2>
                    <p class="text-muted mb-0">اختر موظفاً لتخزين هويته ودوره في الجلسة الحالية.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.CurrentEmployeeName))
                {
                    <div class="alert alert-info">
                        المستخدم الحالي: <strong>@Model.CurrentEmployeeName</strong>
                        @if (!string.IsNullOrWhiteSpace(Model.CurrentEmployeeRole))
                        {
                            <span class="text-muted">(@Model.CurrentEmployeeRole)</span>
                        }
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label asp-for="SelectedEmployeeId" class="form-label fw-bold">اختر الموظف</label>
                        <select asp-for="SelectedEmployeeId" class="form-select rounded-3">
                            <option value="">-- اختر الموظف --</option>
                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.Id">@employee.Name (@employee.Role)</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedEmployeeId" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold">كلمة المرور</label>
                        <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="أدخل كلمة المرور" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 rounded-pill">تسجيل الدخول</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">العودة للرئيسية</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>