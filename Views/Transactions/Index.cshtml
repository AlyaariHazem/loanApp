@model IEnumerable<LoanApp.Models.LoanTransaction>

@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Transactions</h2>
    <button type="button" class="btn btn-primary shadow-sm px-4 rounded-pill" onclick="showModal('@Url.Action("Create")', 'New Transaction')">
        <i class="bi bi-plus-circle me-2"></i>New Transaction
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3">Date</th>
                    <th class="py-3">Lender</th>
                    <th class="py-3">Borrower</th>
                    <th class="py-3">Amount</th>
                    <th class="pe-4 py-3">Note</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 text-muted">@item.CreatedAt.ToShortDateString()</td>
                        <td class="fw-medium text-success">@item.Lender?.Name</td>
                        <td class="fw-medium text-danger">@item.Borrower?.Name</td>
                        <td class="fw-bold text-dark">@item.Amount.ToString("C")</td>
                        <td class="pe-4 small text-muted">@item.Note</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

