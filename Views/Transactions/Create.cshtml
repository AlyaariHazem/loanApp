@model LoanApp.Models.LoanTransaction

@{
    Layout = null;
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    @if (ViewBag.IsAdmin == true)
    {
        <div class="mb-3 text-start">
            <label asp-for="LenderId" class="form-label fw-bold">المقرض</label>
            <select asp-for="LenderId" class="form-select rounded-3 text-start" asp-items="ViewBag.LenderId">
                <option value="">-- اختر المقرض --</option>
            </select>
            <span asp-validation-for="LenderId" class="text-danger small"></span>
        </div>
    }
    else
    {
        <input asp-for="LenderId" type="hidden" value="@ViewBag.CurrentEmployeeId" />
        <div class="mb-3 text-start">
            <label class="form-label fw-bold">المقرض</label>
            <input class="form-control rounded-3" value="@ViewBag.CurrentEmployeeName" readonly />
        </div>
    }
    <div class="mb-3 text-start">
        <label asp-for="BorrowerId" class="form-label fw-bold">المقترض</label>
        <select asp-for="BorrowerId" class="form-select rounded-3 text-start" asp-items="ViewBag.BorrowerId">
            <option value="">-- اختر المقترض --</option>
        </select>
        <span asp-validation-for="BorrowerId" class="text-danger small"></span>
    </div>
    <div class="mb-3 text-start">
        <label asp-for="Amount" class="form-label fw-bold">المبلغ</label>
        <div class="input-group" dir="ltr">
            <span class="input-group-text bg-light border-end-0">$</span>
            <input asp-for="Amount" class="form-control rounded-end-3 border-start-0 text-start" type="number" step="0.01" placeholder="0.00" />
        </div>
        <div class="form-text">يمكن إدخال مبلغ سالب لعكس الاتجاه تلقائياً (المقترض يصبح مقرضاً والعكس).</div>
        <span asp-validation-for="Amount" class="text-danger small"></span>
    </div>
    <div class="mb-4 text-start">
        <label asp-for="Note" class="form-label fw-bold">الملاحظات</label>
        <textarea asp-for="Note" class="form-control rounded-3" rows="2" placeholder="أضف وصفاً اختيارياً..."></textarea>
        <span asp-validation-for="Note" class="text-danger small"></span>
    </div>
    <div class="modal-footer border-0 px-0 pb-0">
        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">إلغاء</button>
        <button type="submit" class="btn btn-primary px-4 shadow-sm">تسجيل العملية</button>
    </div>
</form>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

