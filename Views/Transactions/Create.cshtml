@model LoanApp.Models.LoanTransaction

@{
    Layout = null;
}

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="LenderId" class="form-label fw-bold">Lender</label>
        <select asp-for="LenderId" class ="form-select rounded-3" asp-items="ViewBag.LenderId">
            <option value="">-- Choose Lender --</option>
        </select>
        <span asp-validation-for="LenderId" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="BorrowerId" class="form-label fw-bold">Borrower</label>
        <select asp-for="BorrowerId" class ="form-select rounded-3" asp-items="ViewBag.BorrowerId">
            <option value="">-- Choose Borrower --</option>
        </select>
        <span asp-validation-for="BorrowerId" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Amount" class="form-label fw-bold">Amount</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0">$</span>
            <input asp-for="Amount" class="form-control rounded-end-3 border-start-0" type="number" step="0.01" placeholder="0.00" />
        </div>
        <span asp-validation-for="Amount" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Note" class="form-label fw-bold">Note</label>
        <textarea asp-for="Note" class="form-control rounded-3" rows="2" placeholder="Optional description..."></textarea>
        <span asp-validation-for="Note" class="text-danger small"></span>
    </div>
    <div class="modal-footer border-0 px-0 pb-0">
        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary px-4 shadow-sm">Record Transaction</button>
    </div>
</form>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

