@model LoanApp.Models.LoanTransaction

@{
    ViewData["Title"] = "Add Transaction";
}

<h2>Add Transaction</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="LenderId" class="control-label"></label>
                <select asp-for="LenderId" class ="form-control" asp-items="ViewBag.LenderId">
                    <option value="">-- Select Lender --</option>
                </select>
                <span asp-validation-for="LenderId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="BorrowerId" class="control-label"></label>
                <select asp-for="BorrowerId" class ="form-control" asp-items="ViewBag.BorrowerId">
                    <option value="">-- Select Borrower --</option>
                </select>
                <span asp-validation-for="BorrowerId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Note" class="control-label"></label>
                <input asp-for="Note" class="form-control" />
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
