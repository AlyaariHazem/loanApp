@model LoanApp.Models.Employee

@{
    Layout = null;
}

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-bold">الاسم الكامل</label>
        <input asp-for="Name" class="form-control rounded-3" placeholder="أدخل اسم الموظف" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Department" class="form-label fw-bold">القسم</label>
        <input asp-for="Department" class="form-control rounded-3" placeholder="مثلاً: الموارد البشرية، الهندسة" />
        <span asp-validation-for="Department" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Phone" class="form-label fw-bold">رقم الهاتف</label>
        <input asp-for="Phone" class="form-control rounded-3" placeholder="+967..." />
        <span asp-validation-for="Phone" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Role" class="form-label fw-bold">الدور</label>
        <select asp-for="Role" class="form-select rounded-3">
            <option value="Employee">Employee</option>
            <option value="Admin">Admin</option>
        </select>
        <div class="form-text">Employee هو الافتراضي، وAdmin يتيح الوصول إلى الصفحات الإدارية.</div>
        <span asp-validation-for="Role" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Password" class="form-label fw-bold">كلمة المرور</label>
        <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="6 أحرف على الأقل" />
        <div class="form-text">يتم تخزين كلمة المرور بشكل مشفر (Hash + Salt).</div>
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>
    <div class="modal-footer border-0 px-0 pb-0">
        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">إلغاء</button>
        <button type="submit" class="btn btn-primary px-4 shadow-sm">حفظ الموظف</button>
    </div>
</form>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

